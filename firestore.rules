rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isStakeholder() {
      return isSignedIn() && getUserData().role == 'stakeholder';
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == request.auth.uid 
          && data.email is string && data.email.size() < 100
          && data.role in ['client', 'stakeholder']
          && data.keys().hasAll(['userId', 'email', 'role'])
          && data.keys().size() >= 3;
      }

      allow get: if isOwner(userId) || isStakeholder() || isAdmin();
      allow list: if isStakeholder() || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])
      );
    }

    // 2. Estates Collection (Publicly readable)
    match /estates/{estateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Plots Collection
    match /plots/{plotId} {
      allow read: if true;
      // Booking logic could be more complex, but for now only Admin/System can write
      allow write: if isAdmin();
    }

    // 4. Service Requests
    match /serviceRequests/{requestId} {
      function isValidRequest(data) {
        return data.userId == request.auth.uid 
          && data.status is string
          && data.type is string
          && data.keys().hasAll(['userId', 'type', 'status'])
          && data.keys().size() >= 3;
      }

      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isStakeholder() || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isStakeholder() || isAdmin());
      allow create: if isSignedIn() && isValidRequest(incoming());
      allow update: if isSignedIn() && (
        (isOwner(resource.data.userId) && incoming().diff(existing()).affectedKeys().hasOnly(['documents'])) ||
        isAdmin()
      );
    }

    // 5. Invoices
    match /invoices/{invoiceId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isStakeholder() || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isStakeholder() || isAdmin());
      allow write: if isAdmin();
    }
  }
}
